# ============================================
# FREELANCEFLOW - Complete .gitignore
# ============================================

# ------------------------------
# Dependencies
# ------------------------------
/node_modules
/client/node_modules
/server/node_modules
/.pnp
.pnp.js

# ------------------------------
# Environment Variables
# ------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# ------------------------------
# Build Outputs
# ------------------------------
/dist
/build
/client/build
/server/build
.next/
out/

# ------------------------------
# Logs
# ------------------------------
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# ------------------------------
# Testing
# ------------------------------
/coverage
.nyc_output/
*.test.js
*.spec.js

# ------------------------------
# IDE / Editor Files
# ------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.iml

# ------------------------------
# OS Files
# ------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ------------------------------
# Database
# ------------------------------
*.sqlite
*.db
*.sqlite3

# ------------------------------
# Uploads / Temporary Files
# ------------------------------
/uploads
/temp
/tmp
*.tmp

# ------------------------------
# SSL / Security
# ------------------------------
*.pem
*.key
*.crt
*.p12

# ------------------------------
# Package Manager Files
# ------------------------------
package-lock.json
yarn.lock
pnpm-lock.yaml

# ------------------------------
# Misc
# ------------------------------
*.bak
*.orig
*.log
*.pid
*.seed
*.pid.lock
*.tgz
*.rar

# ------------------------------
# Application Specific
# ------------------------------
# Backup files
*.backup

# Console logs
console.log

# Session files
session-*

# User uploads
/public/uploads/
/private/uploads/

# Environment specific
.env.production
.env.staging
.env.development